<script>
(function () {
  const shapes = [
    // original blobs
    [52,33, 88,25,95,40,92,50, 89,65,68,70,42,68, 15,70,5,60,8,50,   10,35,22,28,52,33],
    [38,30, 72,22,96,38,94,54, 92,68,62,72,30,70,  5,72,3,58,6,46,    8,30,15,24,38,30],
    [58,32, 88,26,97,42,92,55, 88,68,68,72,42,70, 14,72,5,60,10,48,  14,34,28,26,58,32],
    [54,5,  74,5,78,30,76,52,  74,74,66,96,50,95, 34,96,26,72,26,50, 26,28,34,5,54,5  ],
    [58,8,  80,8,80,32,78,54,  76,76,66,95,50,94, 32,95,22,74,24,52, 24,28,36,8,58,8  ],
    // wide/squat — fat sides, compressed top and bottom
    [50,28, 76,14,94,28,94,50, 94,72,76,86,50,72, 24,86,6,72,6,50,   6,28,24,14,50,28 ],
    // tight diamond — near-straight sides, sharp corners
    [50,2,  62,2,92,38,92,50,  92,62,62,98,50,98, 38,98,8,62,8,50,   8,38,38,2,50,2   ],
    // asymmetric — heavy lower-left, light upper-right
    [35,15, 68,4,96,18,97,50,  98,80,68,96,45,95, 18,94,4,76,5,50,   4,24,8,18,35,15  ],
  ];
  // All points collapsed to centre of the 100×100 viewBox
  const DOT = [50,50, 50,50,50,50,50,50, 50,50,50,50,50,50, 50,50,50,50,50,50, 50,50,50,50,50,50];

  function toPath(n) {
    return `M ${n[0]},${n[1]} C ${n[2]},${n[3]} ${n[4]},${n[5]} ${n[6]},${n[7]} C ${n[8]},${n[9]} ${n[10]},${n[11]} ${n[12]},${n[13]} C ${n[14]},${n[15]} ${n[16]},${n[17]} ${n[18]},${n[19]} C ${n[20]},${n[21]} ${n[22]},${n[23]} ${n[24]},${n[25]} Z`;
  }

  // Cubic ease-in — accelerates sharply into the dot
  function easeIn(t)     { return t * t * t; }
  // Back ease-out — overshoots target slightly then settles (spring feel)
  function easeSpring(t) { const c1 = 1.70158, c3 = c1 + 1; return 1 + c3 * Math.pow(t - 1, 3) + c1 * Math.pow(t - 1, 2); }
  function rMs(lo, hi)   { return lo + Math.random() * (hi - lo); }
  function pick()        { return shapes[Math.floor(Math.random() * shapes.length)]; }

  const blob = document.getElementById('orb-blob');
  if (!blob) return;

  const SHRINK = 280;   // ms to collapse — faster, sharper
  const GROW   = 2400;  // ms to bloom — slower, springy

  let current = pick();
  let next    = pick();
  let phase   = 'idle';
  let pStart  = null;

  // Rotate the path around its own centre (50,50) — gradient stays fixed in SVG space
  function snapRotation() {
    blob.setAttribute('transform', 'rotate(' + Math.floor(Math.random() * 360) + ' 50 50)');
  }

  // Kick off from dot on load for a nice entrance
  blob.setAttribute('d', toPath(DOT));
  snapRotation();
  phase = 'growing';
  requestAnimationFrame(function loop(ts) {
    if (!pStart) pStart = ts;

    if (phase === 'shrinking') {
      const t = Math.min((ts - pStart) / SHRINK, 1);
      const e = easeIn(t);
      blob.setAttribute('d', toPath(current.map((v, i) => v + (DOT[i] - v) * e)));
      if (t < 1) { requestAnimationFrame(loop); return; }
      // at dot — snap rotation then pick next shape
      snapRotation();
      next   = pick();
      phase  = 'growing';
      pStart = null;
      requestAnimationFrame(loop);

    } else { // growing
      const t = Math.min((ts - pStart) / GROW, 1);
      const e = easeSpring(t);
      blob.setAttribute('d', toPath(DOT.map((v, i) => v + (next[i] - v) * e)));
      if (t < 1) { requestAnimationFrame(loop); return; }
      // fully grown — hold, then shrink
      current = next;
      phase   = 'idle';
      setTimeout(function () {
        phase  = 'shrinking';
        pStart = null;
        requestAnimationFrame(loop);
      }, rMs(2000, 4500));
    }
  });

  // Signal orb — animate on scroll enter/exit
  const signalWrap = document.querySelector('.signal-orb-wrap');
  if (signalWrap) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          signalWrap.classList.remove('is-visible');
          void signalWrap.offsetHeight; // force reflow to restart animations
          signalWrap.classList.add('is-visible');
        } else {
          signalWrap.classList.remove('is-visible');
        }
      });
    }, { threshold: 0.4 });
    observer.observe(signalWrap);
  }
})();
</script>

