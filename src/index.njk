<script>
(function () {
  var modal = document.getElementById('signal-coming-soon');
  var closeBtn = document.getElementById('signal-coming-soon-close');
  document.querySelectorAll('.signal-open-modal').forEach(function (el) {
    el.addEventListener('click', function (e) {
      e.preventDefault();
      modal.style.display = 'flex';
