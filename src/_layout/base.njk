<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title or "Erik Burns" }}</title>
  <meta name="description" content="{{ description or 'Product designer, hypnotherapist, and agentic AI builder. Twenty-five years shipping products, a clinical practice, and production AI systems used daily.' }}">
  <link rel="icon" type="image/png" href="/assets/img/living-lotus-flat-tr.png">
  <link rel="apple-touch-icon" href="/assets/img/living-lotus-flat-tr.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap">
  <link rel="stylesheet" href="/assets/styles/main.css">
</head>
<body{% if pageClass %} class="{{ pageClass }}"{% endif %}>
  {% include "nav.njk" %}

  <main class="main">
    {{ content | safe }}
  </main>

  <footer class="footer">
    <div class="container">
      <a href="#" aria-label="Signal experience"><img src="/assets/img/living-interface-lotus.png" alt="" class="footer-lotus"></a>
      <p>&copy; 2026 Erik Burns. All rights reserved.</p>
      <p><a href="https://linkedin.com/in/erikburns" target="_blank" rel="noopener">LinkedIn</a> &middot; <a href="mailto:erik@erikburns.com" target="_blank" rel="noopener">erik@erikburns.com</a> &middot; <a href="https://habitualos.com" target="_blank" rel="noopener">HabitualOS</a></p>
    </div>
  </footer>

  <div id="lightbox" class="lightbox">
    <button class="lightbox-close" aria-label="Close">&times;</button>
    <img class="lightbox-img" src="" alt="">
  </div>

  <!-- SVG clip paths (hidden) -->
  <svg width="0" height="0" aria-hidden="true" style="position:absolute;overflow:hidden">
    <defs>
      <!-- Single concave curve on sidemenu right edge -->
      <clipPath id="sidemenu-clip" clipPathUnits="objectBoundingBox">
        <path d="M 0 0 L 1 0 Q 0.92 0.5 1 1 L 0 1 Z"/>
      </clipPath>
    </defs>
  </svg>

  <script>
    (function () {
      var html = document.documentElement;
      // Time-based dark mode: 7pm (19) to 5am (5) in visitor's local timezone
      var hour = new Date().getHours();
      var isNight = hour >= 19 || hour < 5;
      if (isNight) html.setAttribute('data-theme', 'dark');
      var isDark = document.body.classList.contains('page-dark') || isNight;
      var TOP_COLOR = isDark ? '#080d17' : '#f0f4ff';
      var BOTTOM_COLOR = '#080d17';
      function update() {
        var atTop = window.scrollY < 10;
        html.style.backgroundColor = atTop ? TOP_COLOR : BOTTOM_COLOR;
      }
      update();
      window.addEventListener('scroll', update, { passive: true });
    })();
  </script>
  <script src="/assets/js/navigation.js"></script>
  <script src="/assets/js/typewriter.js"></script>
  <script src="/assets/js/gallery.js"></script>
  {# <script src="/assets/js/hero-bars.js"></script> #}
  <script src="/assets/js/arc.js"></script>
  <script src="/assets/js/lotus-sparks.js"></script>
  <script src="/assets/js/signal.js"></script>
</body>
</html>
