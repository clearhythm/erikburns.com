    <script>
    (function () {
      const groups = document.querySelectorAll('#who .who-circle-group');
      const panels = document.querySelectorAll('#who .who-desc');
      function activate(domain) {
        const already = document.querySelector('#who .who-circle-group.active');
        if (already && already.dataset.domain === domain) return;
        groups.forEach(g => {
          if (g.dataset.domain === domain) {
            g.classList.remove('active');
            g.parentNode.appendChild(g); // move to top (resets paint state)
            requestAnimationFrame(() => requestAnimationFrame(() => g.classList.add('active')));
          } else {
            g.classList.remove('active');
          }
        });
        panels.forEach(p => p.classList.toggle('active', p.dataset.domain === domain));
      }
      groups.forEach(g => {
        g.addEventListener('click', () => activate(g.dataset.domain));
        g.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') activate(g.dataset.domain); });
      });
      // Ensure default active circle renders on top on load
      const defaultActive = document.querySelector('#who .who-circle-group.active');
      if (defaultActive) defaultActive.parentNode.appendChild(defaultActive);
    })();
    </script>
