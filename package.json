{
  "name": "erikburns",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "sass src/assets/styles/main.scss:src/assets/css/main.css --style=compressed",
    "watch:css": "sass --watch src/assets/styles/main.scss:src/assets/css/main.css",
    "build": "npm run build:css && npx @11ty/eleventy",
    "start": "concurrently \"npm:watch:css\" \"npx @11ty/eleventy --serve\""
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "concurrently": "^9.0.1",
    "sass": "^1.80.3"
  }
}
